<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="0.0" styleClass="mobile-root" stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aulkhami.pakupos.modules.inventory.view.InventoryView">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-header">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20" />
        </padding>
        <Button
            text="←"
            onAction="#handleBack"
            styleClass="mobile-button-header"
            style="-fx-font-size: 18px;"
            focusTraversable="false"
        />
        <Label text="Inventory Management" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
    </HBox>

    <ScrollPane
        fitToWidth="true"
        style="-fx-background-color: transparent; -fx-background: transparent;"
        VBox.vgrow="ALWAYS"
    >
        <VBox spacing="20.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>

            <Label text="Add New Product" styleClass="mobile-subtitle" />

            <VBox spacing="15.0">
                <!-- Product Name -->
                <VBox spacing="5.0">
                    <Label
                        text="Product Name *"
                        style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"
                    />
                    <TextField
                        fx:id="nameField"
                        promptText="e.g. Martabak Manis Cokelat"
                        styleClass="mobile-input"
                        maxWidth="Infinity"
                    />
                </VBox>

                <!-- Category -->
                <VBox spacing="5.0">
                    <Label
                        text="Category"
                        style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"
                    />
                    <TextField
                        fx:id="categoryField"
                        promptText="e.g. Sweet / Savory"
                        styleClass="mobile-input"
                        maxWidth="Infinity"
                    />
                </VBox>

                <!-- Price & Hidden Stock Field -->
                <VBox spacing="5.0">
                    <Label
                        text="Price (Rp) *"
                        style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"
                    />
                    <TextField
                        fx:id="priceField"
                        promptText="e.g. 25000"
                        styleClass="mobile-input"
                        maxWidth="Infinity"
                    />
                </VBox>

                <!-- Hidden Stock Field to pass Backend Validation without breaking Controller -->
                <TextField
                    fx:id="stockField"
                    text="999"
                    visible="false"
                    managed="false"
                />

                <Button
                    text="SAVE PRODUCT"
                    onAction="#handleSaveProduct"
                    maxWidth="Infinity"
                    styleClass="mobile-button-primary"
                    focusTraversable="false"
                >
                    <VBox.margin>
                        <Insets top="10" />
                    </VBox.margin>
                </Button>
            </VBox>

            <Separator />

            <Label text="Current Inventory" styleClass="mobile-subtitle" />
            
            <!-- Dynamic and Static Custom Cards List -->
            <VBox spacing="12.0">
                <!-- VBox for runtime added products -->
                <VBox fx:id="productListVBox" spacing="12.0" />

                <!-- Mock Product Card 1 -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="inventory-product-card">
                    <padding>
                        <Insets top="14" right="16" bottom="14" left="16"/>
                    </padding>
                    <children>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Martabak Manis" styleClass="inventory-product-name"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Sweet" styleClass="badge, badge-sweet"/>
                                        <Label text="Rp 25.000" styleClass="inventory-product-price"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Button text="🗑️ Delete" styleClass="inventory-delete-btn" focusTraversable="false"/>
                    </children>
                </HBox>

                <!-- Mock Product Card 2 -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="inventory-product-card">
                    <padding>
                        <Insets top="14" right="16" bottom="14" left="16"/>
                    </padding>
                    <children>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Martabak Asin" styleClass="inventory-product-name"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Savory" styleClass="badge, badge-savory"/>
                                        <Label text="Rp 22.000" styleClass="inventory-product-price"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Button text="🗑️ Delete" styleClass="inventory-delete-btn" focusTraversable="false"/>
                    </children>
                </HBox>

                <!-- Mock Product Card 3 -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="inventory-product-card">
                    <padding>
                        <Insets top="14" right="16" bottom="14" left="16"/>
                    </padding>
                    <children>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Martabak Manis Spesial" styleClass="inventory-product-name"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Premium" styleClass="badge, badge-premium"/>
                                        <Label text="Rp 35.000" styleClass="inventory-product-price"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Button text="🗑️ Delete" styleClass="inventory-delete-btn" focusTraversable="false"/>
                    </children>
                </HBox>
            </VBox>

            <Separator />

            <Label text="Quick Help" styleClass="mobile-subtitle" />

            <Label
                text="Fields marked with * are required. Make sure price is a numeric value."
                wrapText="true"
                style="-fx-text-fill: #6c757d; -fx-font-size: 13px;"
            />
        </VBox>
    </ScrollPane>

    <!-- Bottom Nav Placeholder (Keeping consistency) -->
    <HBox alignment="CENTER" spacing="0.0" styleClass="mobile-bottom-nav">
        <Button
            text="Home"
            onAction="#handleBack"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="🏠" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Sales"
            onAction="#handleNewSale"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="🛍️" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Inventory"
            styleClass="mobile-nav-item, active"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="📦" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="More"
            onAction="#handleSettings"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="☰" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
    </HBox>
</VBox>

