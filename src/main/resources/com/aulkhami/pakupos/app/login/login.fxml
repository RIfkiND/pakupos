<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" styleClass="mobile-root" stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aulkhami.pakupos.modules.auth.view.LoginView">

    <padding>
        <Insets bottom="40" left="30" right="30" top="40" />
    </padding>

    <Label styleClass="mobile-title" text="PAKUPOS">
        <font>
            <Font name="System Bold" size="32.0" />
        </font>
    </Label>

    <Label styleClass="mobile-subtitle" text="Aplikasi Kasir Mobile" />

    <VBox fillWidth="true" spacing="10.0">
        <TextField fx:id="usernameField" promptText="Email" styleClass="mobile-input" />
        <PasswordField fx:id="passwordField" promptText="Kata Sandi" styleClass="mobile-input" />
    </VBox>

    <VBox fillWidth="true" spacing="12.0">
        <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="mobile-button-primary" text="MASUK" />
        <Button maxWidth="Infinity" onAction="#handleRegister" styleClass="mobile-button-secondary" text="DAFTAR" />
    </VBox>

</VBox>

