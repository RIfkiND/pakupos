<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="0.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aulkhami.pakupos.modules.settings.view.SettingsView"
      styleClass="mobile-root" stylesheets="@../../css/main.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-header">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20"/>
        </padding>
        <Button
            text="←"
            onAction="#handleBack"
            styleClass="mobile-button-header"
            style="-fx-font-size: 18px;"
            focusTraversable="false"
        />
        <Label text="Settings" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0"/>
            </font>
        </Label>
    </HBox>

    <ScrollPane
        fitToWidth="true"
        style="-fx-background-color: transparent; -fx-background: transparent;"
        VBox.vgrow="ALWAYS"
    >
        <VBox spacing="25.0">
            <padding>
                <Insets top="30" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Profile Section -->
            <VBox alignment="CENTER" spacing="12">
                <StackPane styleClass="profile-image-container">
                    <children>
                        <!-- A premium business logo/store avatar -->
                        <Label text="🏪" style="-fx-font-size: 44px; -fx-text-fill: white;"/>
                    </children>
                </StackPane>
                <VBox alignment="CENTER" spacing="4">
                    <children>
                        <Label fx:id="nameLabel" text="Owner Name" styleClass="profile-name-label"/>
                        <Label fx:id="roleLabel" text="Store Owner" styleClass="profile-role-tag"/>
                    </children>
                </VBox>
            </VBox>

            <!-- Profile Info Card -->
            <VBox spacing="0.0" styleClass="settings-card">
                <children>
                    <!-- Email Row -->
                    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="settings-row">
                        <padding>
                            <Insets top="16" right="20" bottom="16" left="20"/>
                        </padding>
                        <children>
                            <StackPane styleClass="settings-icon-bg, icon-bg-blue">
                                <Label text="📧" style="-fx-font-size: 16px;"/>
                            </StackPane>
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <children>
                                    <Label text="Email Address" styleClass="settings-label-title"/>
                                    <Label fx:id="emailLabel" text="owner@pakupos.com" styleClass="settings-label-value"/>
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- Divider -->
                    <Separator style="-fx-background-color: #f1f3f5;"/>

                    <!-- Password Row with change button pointing to handleUserManagement -->
                    <Button onAction="#handleUserManagement" styleClass="settings-row-btn" maxWidth="Infinity" focusTraversable="false">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <children>
                                    <StackPane styleClass="settings-icon-bg, icon-bg-purple">
                                        <Label text="🔒" style="-fx-font-size: 16px;"/>
                                    </StackPane>
                                    <VBox HBox.hgrow="ALWAYS" spacing="2" alignment="CENTER_LEFT">
                                        <children>
                                            <Label text="Password" styleClass="settings-label-title"/>
                                            <Label text="••••••••" styleClass="settings-label-value"/>
                                        </children>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="Change ›" styleClass="settings-change-link"/>
                                </children>
                            </HBox>
                        </graphic>
                    </Button>
                </children>
            </VBox>

            <!-- Hidden Nodes for Controller compatibility -->
            <Label fx:id="phoneLabel" text="-" visible="false" managed="false" />
            <VBox fx:id="adminSection" visible="false" managed="false" />

            <!-- Logout -->
            <Button
                text="LOGOUT 🚪"
                onAction="#handleLogout"
                maxWidth="Infinity"
                styleClass="mobile-button-secondary"
                style="-fx-text-fill: #dc3545; -fx-border-color: #dc3545;"
                focusTraversable="false"
            >
                <VBox.margin>
                    <Insets top="10" bottom="20"/>
                </VBox.margin>
            </Button>

            <Label text="App Version 1.0.0" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #adb5bd; -fx-font-size: 11px;"/>
        </VBox>
    </ScrollPane>

    <!-- Bottom Nav -->
    <HBox alignment="CENTER" spacing="0.0" styleClass="mobile-bottom-nav">
        <Button
            text="Home"
            onAction="#handleBack"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="🏠" styleClass="mobile-nav-icon"/>
            </graphic>
        </Button>
        <Button
            text="Sales"
            onAction="#handleNewSale"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="🛍️" styleClass="mobile-nav-icon"/>
            </graphic>
        </Button>
        <Button
            text="Inventory"
            onAction="#handleInventory"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="📦" styleClass="mobile-nav-icon"/>
            </graphic>
        </Button>
        <Button
            text="More"
            styleClass="mobile-nav-item, active"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="☰" styleClass="mobile-nav-icon"/>
            </graphic>
        </Button>
    </HBox>
</VBox>

