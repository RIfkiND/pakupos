<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<StackPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.aulkhami.pakupos.modules.pos.view.POSView"
    styleClass="mobile-root"
    stylesheets="@../../css/main.css"

>

    <VBox spacing="0.0" style="-fx-background-color: #f8f9fa;">
        <!-- Header (Fixed Top) -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="mobile-header">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20" />
            </padding>
            <Button
                text="←"
                onAction="#handleBack"
                styleClass="mobile-button-header"
                focusTraversable="false"
            />
            <Label text="Kasir (POS)" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>
        </HBox>

        <!-- Stepper Navigation (TabPane) -->
        <TabPane fx:id="posTabPane" side="TOP" tabClosingPolicy="UNAVAILABLE" styleClass="pos-stepper-tabpane" VBox.vgrow="ALWAYS">
            <tabs>
                <!-- STEP 1: CHOOSE PRODUCTS -->
                <Tab text="1. Belanja">
                    <content>
                        <StackPane>
                            <VBox spacing="0.0">
                                <!-- Customer Input Area -->
                                <VBox spacing="10.0">
                                    <padding>
                                        <Insets top="16" right="16" bottom="4" left="16" />
                                    </padding>
                                    <VBox spacing="10.0" styleClass="customer-card-container">
                                        <children>
                                            <Label
                                                text="DETAIL PELANGGAN"
                                                styleClass="section-title"
                                            />
                                            <TextField
                                                fx:id="customerNameField"
                                                promptText="Masukkan Nama Pelanggan"
                                                styleClass="mobile-input"
                                                maxWidth="Infinity"
                                            />
                                        </children>
                                    </VBox>
                                </VBox>

                                <!-- Search Products Area -->
                                <VBox spacing="10.0">
                                    <padding>
                                        <Insets top="0" right="16" bottom="8" left="16" />
                                    </padding>
                                    <VBox spacing="10.0" styleClass="customer-card-container">
                                        <children>
                                            <Label
                                                text="CARI PRODUK"
                                                styleClass="section-title"
                                            />
                                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                <children>
                                                    <TextField
                                                        fx:id="searchField"
                                                        promptText="Cari produk berdasarkan nama..."
                                                        styleClass="mobile-input"
                                                        HBox.hgrow="ALWAYS"
                                                    />
                                                    <Button
                                                        text="Cari"
                                                        styleClass="mobile-button-search"
                                                        focusTraversable="false"
                                                    />
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>
                                </VBox>

                                <!-- Product Selection List -->
                                <ScrollPane
                                    fitToWidth="true"
                                    style="-fx-background-color: transparent; -fx-background: transparent;"
                                    VBox.vgrow="ALWAYS"
                                >
                                    <VBox spacing="15.0">
                                        <padding>
                                            <Insets top="12" right="16" bottom="100" left="16" />
                                        </padding>
                                        <Label
                                            text="PILIH PRODUK"
                                            styleClass="section-title"
                                        />
                                        <VBox fx:id="productListBox" spacing="10.0">
                                            <!-- Dynamic product cards will be rendered here -->
                                        </VBox>
                                    </VBox>
                                </ScrollPane>
                            </VBox>

                            <!-- Floating Cart Menu (Sticky at bottom, only in Step 1) -->
                            <VBox
                                alignment="BOTTOM_CENTER"
                                mouseTransparent="false"
                                pickOnBounds="false"
                                maxWidth="Infinity"
                            >
                                <HBox
                                    alignment="CENTER_LEFT"
                                    spacing="15.0"
                                    styleClass="mobile-floating-cart"
                                    maxWidth="800"
                                >
                                    <StackPane.margin>
                                        <Insets bottom="25" left="20" right="20" />
                                    </StackPane.margin>
                                    <padding>
                                        <Insets top="12" right="16" bottom="12" left="16" />
                                    </padding>

                                    <HBox styleClass="cart-badge-container">
                                        <children>
                                            <Label
                                                text="🛒"
                                                style="-fx-text-fill: white; -fx-font-size: 18px;"
                                            />
                                        </children>
                                    </HBox>

                                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="2">
                                        <Label
                                            fx:id="itemCountLabel"
                                            text="0 Items"
                                            style="-fx-text-fill: #adb5bd; -fx-font-size: 12px; -fx-font-weight: bold;"
                                        />
                                        <Label
                                            fx:id="totalPriceLabel"
                                            text="Rp 0"
                                            style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"
                                        />
                                    </VBox>

                                    <Button
                                        text="BAYAR"
                                        onAction="#goToStep2"
                                        styleClass="mobile-button-checkout"
                                        focusTraversable="false"
                                    />
                                </HBox>
                            </VBox>
                        </StackPane>
                    </content>
                </Tab>

                <!-- STEP 2: CHECKOUT DETAILS & PAYMENT -->
                <Tab text="2. Pembayaran">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <VBox spacing="20.0">
                                <padding>
                                    <Insets top="20" right="16" bottom="40" left="16" />
                                </padding>
                                
                                <Label text="TINJAU PESANAN" styleClass="section-title" />
                                
                                <!-- Detailed Receipt Invoice Card -->
                                <VBox spacing="14.0" styleClass="receipt-card">
                                    <children>
                                        <Label text="RINGKASAN TAGIHAN" styleClass="receipt-title" maxWidth="Infinity" alignment="CENTER" />
                                        <Separator style="-fx-background-color: #dee2e6;" />
                                        
                                        <VBox fx:id="receiptItemsBox" spacing="12.0">
                                            <!-- Dynamic receipt items will be added here -->
                                        </VBox>
                                        
                                        <Separator style="-fx-background-color: #dee2e6;" />
                                        
                                        <!-- Calculation breakdown -->
                                        <VBox spacing="8.0">
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="Subtotal" style="-fx-text-fill: #718096; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                <Label fx:id="subtotalLabel" text="Rp 0" style="-fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-font-size: 13px;" />
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="PPN (11%)" style="-fx-text-fill: #718096; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                <Label fx:id="taxLabel" text="Rp 0" style="-fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-font-size: 13px;" />
                                            </HBox>
                                        </VBox>
                                        
                                        <Separator style="-fx-background-color: #dee2e6;" />
                                        
                                        <!-- Grand Total -->
                                        <HBox alignment="CENTER_LEFT">
                                            <Label text="Total Keseluruhan" styleClass="receipt-total-label" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                            <Label fx:id="grandTotalLabel" text="Rp 0" styleClass="receipt-total-value" />
                                        </HBox>
                                    </children>
                                </VBox>
                                
                                <Label text="PILIH METODE PEMBAYARAN" styleClass="section-title" />
                                
                                <!-- Payment Method Cards -->
                                <VBox spacing="14.0">
                                    <!-- Option 1: Cash -->
                                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="payment-method-card" onMouseClicked="#selectCashPayment" style="-fx-border-color: #4364f7; -fx-effect: dropshadow(three-pass-box, rgba(67, 100, 247, 0.1), 12, 0, 0, 4); -fx-cursor: hand;">
                                        <children>
                                            <Label text="💵" styleClass="payment-method-icon" />
                                            <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                                                <Label text="Tunai (Cash)" styleClass="payment-method-title" style="-fx-text-fill: #0052d4;" />
                                                <Label text="Klik untuk membayar dengan uang tunai" styleClass="payment-method-desc" />
                                            </VBox>
                                        </children>
                                    </HBox>
                                    
                                    <!-- Option 2: QRIS -->
                                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="payment-method-card" onMouseClicked="#selectQrisPayment" style="-fx-border-color: #4364f7; -fx-effect: dropshadow(three-pass-box, rgba(67, 100, 247, 0.1), 12, 0, 0, 4); -fx-cursor: hand;">
                                        <children>
                                            <Label text="📱" styleClass="payment-method-icon" />
                                            <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                                                <Label text="QRIS / Dompet Digital" styleClass="payment-method-title" style="-fx-text-fill: #0052d4;" />
                                                <Label text="Klik untuk membayar menggunakan QRIS" styleClass="payment-method-desc" />
                                            </VBox>
                                        </children>
                                    </HBox>
                                </VBox>
                                
                                <!-- Cancel Transaction Button -->
                                <VBox alignment="CENTER" spacing="10.0">
                                    <Button text="BATALKAN TRANSAKSI" onAction="#handleCancelTransaction" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 18px; -fx-pref-height: 40px; -fx-pref-width: 320;" />
                                </VBox>
                            </VBox>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- STEP 3: CASH CALCULATOR -->
                <Tab text="3. Tunai">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <VBox spacing="20.0">
                                <padding>
                                    <Insets top="20" right="16" bottom="40" left="16" />
                                </padding>
                                
                                <!-- Total Bill Card (Premium Gradient) -->
                                <VBox spacing="6.0" style="-fx-background-color: linear-gradient(to right, #0052d4, #4364f7); -fx-background-radius: 16px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(67, 100, 247, 0.2), 12, 0, 0, 4);">
                                    <children>
                                        <Label text="TOTAL TAGIHAN" style="-fx-text-fill: rgba(255, 255, 255, 0.8); -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;" />
                                        <Label fx:id="cashGrandTotalLabel" text="Rp 0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>
                                
                                <!-- Form Input Card -->
                                <VBox spacing="16.0" styleClass="customer-card-container">
                                    <children>
                                        <Label text="MASUKKAN NOMINAL UANG PELANGGAN" styleClass="section-title" />
                                        
                                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 10px; -fx-border-color: #e0e0e0; -fx-border-radius: 10px; -fx-border-width: 1px; -fx-padding: 2px 14px;">
                                            <children>
                                                <Label text="Rp" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                                <TextField fx:id="cashInputField" promptText="0" style="-fx-background-color: transparent; -fx-pref-height: 44px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3748; -fx-padding: 0;" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        
                                        <!-- Quick Cash Selector -->
                                        <VBox spacing="8.0">
                                            <Label text="UANG CEPAT" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0;" />
                                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                <children>
                                                    <Button text="Uang Pas" onAction="#setExactCash" style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 20px; -fx-padding: 6px 14px; -fx-cursor: hand;" />
                                                    <Button text="Rp 50.000" onAction="#setFiftyThousand" style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 20px; -fx-padding: 6px 14px; -fx-cursor: hand;" />
                                                    <Button text="Rp 100.000" onAction="#setOneHundredThousand" style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 20px; -fx-padding: 6px 14px; -fx-cursor: hand;" />
                                                </children>
                                            </HBox>
                                        </VBox>
                                    </children>
                                </VBox>
                                
                                <!-- Change Calculation Display Card -->
                                <VBox spacing="10.0" style="-fx-background-color: #f0fff4; -fx-background-radius: 16px; -fx-border-color: #c6f6d5; -fx-border-width: 1px; -fx-padding: 16px;">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label text="💰" style="-fx-font-size: 20px;" />
                                                <VBox spacing="2">
                                                    <children>
                                                        <Label text="KEMBALIAN YANG HARUS DIBERIKAN" style="-fx-text-fill: #2f855a; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;" />
                                                        <Label fx:id="changeLabel" text="Rp 0" style="-fx-text-fill: #276749; -fx-font-size: 20px; -fx-font-weight: bold;" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                
                                <!-- Complete Transaction Button -->
                                <VBox alignment="CENTER" spacing="10.0">
                                    <Button text="SELESAIKAN TRANSAKSI TUNAI" onAction="#handleCheckout" styleClass="mobile-button-checkout" style="-fx-background-color: linear-gradient(to bottom, #1f9d55, #157347); -fx-pref-width: 320; -fx-effect: dropshadow(three-pass-box, rgba(25, 135, 84, 0.4), 10, 0, 0, 3);" />
                                    
                                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                                        <Button text="KEMBALI" onAction="#goBackToPayment" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 18px; -fx-pref-height: 40px; -fx-pref-width: 155;" />
                                        <Button text="BATALKAN" onAction="#handleCancelTransaction" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 18px; -fx-pref-height: 40px; -fx-pref-width: 155;" />
                                    </HBox>
                                </VBox>
                            </VBox>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- STEP 4: QRIS SCAN -->
                <Tab text="4. QRIS">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <VBox spacing="20.0" alignment="TOP_CENTER">
                                <padding>
                                    <Insets top="20" right="16" bottom="40" left="16" />
                                </padding>
                                
                                <Label text="PINDAI KODE QRIS UNTUK MEMBAYAR" styleClass="section-title" />
                                
                                <!-- QRIS Image Scanner Frame Card -->
                                <VBox alignment="CENTER" spacing="15.0" maxWidth="340.0" style="-fx-background-color: white; -fx-background-radius: 24px; -fx-border-radius: 24px; -fx-border-color: #dee2e6; -fx-border-width: 1px; -fx-padding: 24px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.06), 16, 0, 0, 6);">
                                    <children>
                                        <ImageView fitWidth="210" fitHeight="210" preserveRatio="true">
                                            <image>
                                                <Image url="@images/mock_qris_code.png" />
                                            </image>
                                        </ImageView>
                                        
                                        <VBox alignment="CENTER" spacing="4.0">
                                            <children>
                                                <Label fx:id="qrisGrandTotalLabel" text="Rp 0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0052d4;" />
                                                <Label text="PAKU Martabak - POS Terminal" style="-fx-font-size: 12px; -fx-text-fill: #718096; -fx-font-weight: bold;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                                
                                <!-- Next: Complete Checkout Button -->
                                <VBox alignment="CENTER" spacing="10.0">
                                    <Button text="SELESAIKAN TRANSAKSI QRIS" onAction="#handleCheckout" styleClass="mobile-button-checkout" style="-fx-background-color: linear-gradient(to bottom, #1f9d55, #157347); -fx-pref-width: 320; -fx-effect: dropshadow(three-pass-box, rgba(25, 135, 84, 0.4), 10, 0, 0, 3);" />
                                    
                                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                                        <Button text="KEMBALI" onAction="#goBackToPayment" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 18px; -fx-pref-height: 40px; -fx-pref-width: 155;" />
                                        <Button text="BATALKAN" onAction="#handleCancelTransaction" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 18px; -fx-pref-height: 40px; -fx-pref-width: 155;" />
                                    </HBox>
                                </VBox>
                            </VBox>
                        </ScrollPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </VBox>

</StackPane>

