<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="0.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aulkhami.pakupos.modules.user.view.UserManagementView"
      styleClass="mobile-root" stylesheets="@../../css/main.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-header">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20"/>
        </padding>
        <Button
            text="←"
            onAction="#handleBack"
            styleClass="mobile-button-header"
            style="-fx-font-size: 18px;"
            focusTraversable="false"
        />
        <Label text="Change Password" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0"/>
            </font>
        </Label>
    </HBox>

    <ScrollPane
        fitToWidth="true"
        style="-fx-background-color: transparent; -fx-background: transparent;"
        VBox.vgrow="ALWAYS"
    >
        <VBox spacing="25.0">
            <padding>
                <Insets top="30" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Top Header Visual -->
            <VBox alignment="CENTER" spacing="12">
                <StackPane styleClass="lock-icon-container">
                    <children>
                        <Label text="🔐" style="-fx-font-size: 40px;"/>
                    </children>
                </StackPane>
                <Label text="Update Security" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a202c;"/>
                <Label
                    text="Keep your account secure by entering your current password and choosing a strong new one."
                    alignment="CENTER"
                    wrapText="true"
                    style="-fx-text-fill: #718096; -fx-font-size: 12px; -fx-text-alignment: center;"
                />
            </VBox>

            <!-- Change Password Form Card -->
            <VBox spacing="18.0" styleClass="settings-card" style="-fx-padding: 24;">
                <children>
                    <!-- Current Password -->
                    <VBox spacing="6.0">
                        <Label text="Current Password *" styleClass="settings-label-title" style="-fx-font-size: 12px;"/>
                        <!-- PasswordField using nameField fx:id to satisfy Controller -->
                        <PasswordField
                            fx:id="nameField"
                            promptText="Enter current password"
                            styleClass="mobile-input"
                        />
                    </VBox>

                    <!-- New Password -->
                    <VBox spacing="6.0">
                        <Label text="New Password *" styleClass="settings-label-title" style="-fx-font-size: 12px;"/>
                        <PasswordField
                            fx:id="passwordField"
                            promptText="Minimum 8 characters"
                            styleClass="mobile-input"
                        />
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="6.0">
                        <Label text="Confirm New Password *" styleClass="settings-label-title" style="-fx-font-size: 12px;"/>
                        <!-- PasswordField using emailField fx:id to satisfy Controller -->
                        <PasswordField
                            fx:id="emailField"
                            promptText="Re-enter new password"
                            styleClass="mobile-input"
                        />
                    </VBox>

                    <Button
                        text="UPDATE PASSWORD"
                        onAction="#handleAddKaryawan"
                        maxWidth="Infinity"
                        styleClass="mobile-button-primary"
                        focusTraversable="false"
                    >
                        <VBox.margin>
                            <Insets top="10"/>
                        </VBox.margin>
                    </Button>
                </children>
            </VBox>

            <!-- Hidden Fields for Controller compatibility -->
            <TextField fx:id="phoneField" text="12345678" visible="false" managed="false"/>
            <VBox fx:id="userListVBox" visible="false" managed="false"/>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </ScrollPane>
</VBox>

