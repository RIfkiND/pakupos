<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<VBox
    spacing="0.0"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.aulkhami.pakupos.modules.dashboard.view.DashboardView"
    styleClass="mobile-root"
    stylesheets="@../../css/main.css"
>

    <!-- Top Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-header">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20" />
        </padding>
        <Label text="Dasbor" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleLogout" styleClass="mobile-logout-btn" text="Keluar 🚪" focusTraversable="false" />
    </HBox>

    <ScrollPane
        fitToWidth="true"
        style="-fx-background-color: transparent; -fx-background: transparent;"
        VBox.vgrow="ALWAYS"
    >
        <VBox spacing="20.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>

            <Label text="Selamat datang kembali!" styleClass="mobile-subtitle" />

            <!-- Stats Row -->
            <HBox spacing="10.0" fillHeight="true">
                <VBox
                    spacing="5.0"
                    styleClass="mobile-stats-card"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                >
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15" />
                    </padding>
                    <Label
                        text="Total Penjualan"
                        style="-fx-text-fill: white; -fx-font-size: 12px;"
                    />
                    <Label
                        fx:id="totalSalesLabel"
                        text="Rp 0"
                        style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
                    />
                </VBox>
                <VBox
                    spacing="5.0"
                    styleClass="mobile-stats-card-alt"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                >
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15" />
                    </padding>
                    <Label
                        text="Pesanan"
                        style="-fx-text-fill: white; -fx-font-size: 12px;"
                    />
                    <Label
                        fx:id="totalOrdersLabel"
                        text="0"
                        style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
                    />
                </VBox>
            </HBox>

            <Label text="Tindakan Cepat" styleClass="mobile-subtitle" />

            <!-- POS Actions Slider with Premium Colored Icons -->
            <ScrollPane fx:id="quickActionsScrollPane" pannable="true" hbarPolicy="NEVER" vbarPolicy="NEVER" fitToHeight="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
                <HBox fx:id="quickActionsHBox" spacing="15.0" alignment="CENTER_LEFT" style="-fx-padding: 5 5 15 5;">
                    <!-- New Sale -->
                    <Button
                        onAction="#handleNewSale"
                        minWidth="100"
                        minHeight="100"
                        styleClass="dashboard-menu-btn"
                        style="-fx-background-radius: 20px;"
                        focusTraversable="false"
                    >
                        <graphic>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <StackPane styleClass="menu-icon-container, icon-bg-blue">
                                        <children>
                                            <Label text="🛒" style="-fx-font-size: 20px; -fx-text-fill: white;" />
                                        </children>
                                    </StackPane>
                                    <Label text="Penjualan" styleClass="menu-btn-label" style="-fx-font-size: 11px;" />
                                </children>
                            </VBox>
                        </graphic>
                    </Button>

                    <!-- Inventory -->
                    <Button
                        onAction="#handleInventory"
                        minWidth="100"
                        minHeight="100"
                        styleClass="dashboard-menu-btn"
                        style="-fx-background-radius: 20px;"
                        focusTraversable="false"
                    >
                        <graphic>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <StackPane styleClass="menu-icon-container, icon-bg-purple">
                                        <children>
                                            <Label text="📦" style="-fx-font-size: 20px; -fx-text-fill: white;" />
                                        </children>
                                    </StackPane>
                                    <Label text="Inventaris" styleClass="menu-btn-label" style="-fx-font-size: 11px;" />
                                </children>
                            </VBox>
                        </graphic>
                    </Button>

                    <!-- Reports -->
                    <Button
                        onAction="#handleReports"
                        minWidth="100"
                        minHeight="100"
                        styleClass="dashboard-menu-btn"
                        style="-fx-background-radius: 20px;"
                        focusTraversable="false"
                    >
                        <graphic>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <StackPane styleClass="menu-icon-container, icon-bg-green">
                                        <children>
                                            <Label text="📊" style="-fx-font-size: 20px; -fx-text-fill: white;" />
                                        </children>
                                    </StackPane>
                                    <Label text="Laporan" styleClass="menu-btn-label" style="-fx-font-size: 11px;" />
                                </children>
                            </VBox>
                        </graphic>
                    </Button>

                    <!-- Settings -->
                    <Button
                        onAction="#handleSettings"
                        minWidth="100"
                        minHeight="100"
                        styleClass="dashboard-menu-btn"
                        style="-fx-background-radius: 20px;"
                        focusTraversable="false"
                    >
                        <graphic>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <StackPane styleClass="menu-icon-container, icon-bg-orange">
                                        <children>
                                            <Label text="⚙️" style="-fx-font-size: 20px; -fx-text-fill: white;" />
                                        </children>
                                    </StackPane>
                                    <Label text="Pengaturan" styleClass="menu-btn-label" style="-fx-font-size: 11px;" />
                                </children>
                            </VBox>
                        </graphic>
                    </Button>
                    
                    <!-- Tambah Kategori -->
                    <Button
                        onAction="#handleAddCategory"
                        minWidth="100"
                        minHeight="100"
                        styleClass="dashboard-menu-btn"
                        style="-fx-background-radius: 20px;"
                        focusTraversable="false"
                    >
                        <graphic>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <StackPane styleClass="menu-icon-container" style="-fx-background-color: linear-gradient(to bottom right, #e83e8c, #c2255c); -fx-effect: dropshadow(three-pass-box, rgba(232, 62, 140, 0.25), 8, 0, 0, 3);">
                                        <children>
                                            <Label text="🏷️" style="-fx-font-size: 20px; -fx-text-fill: white;" />
                                        </children>
                                    </StackPane>
                                    <Label text="Kategori" styleClass="menu-btn-label" style="-fx-font-size: 11px;" />
                                </children>
                            </VBox>
                        </graphic>
                    </Button>
                </HBox>
            </ScrollPane>

            <!-- Recent Transactions styled identical to Reports list -->
            <Label text="Transaksi Terakhir" styleClass="mobile-subtitle" />

            <VBox fx:id="recentTransactionsVBox" spacing="10.0" />
        </VBox>
    </ScrollPane>

    <!-- Bottom Nav -->
    <HBox alignment="CENTER" spacing="0.0" styleClass="mobile-bottom-nav">
        <Button
            text="Beranda"
            styleClass="mobile-nav-item, active"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="🏠" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Penjualan"
            onAction="#handleNewSale"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="🛍️" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Inventaris"
            onAction="#handleInventory"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="📦" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Lainnya"
            onAction="#handleSettings"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="☰" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
    </HBox>
</VBox>

