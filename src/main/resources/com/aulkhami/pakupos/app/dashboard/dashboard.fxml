<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<VBox
    spacing="0.0"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.aulkhami.pakupos.modules.dashboard.view.DashboardView"
    styleClass="mobile-root"
    stylesheets="@../../css/main.css"
>

    <!-- Top Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-header">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20" />
        </padding>
        <Label text="Dasbor" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleLogout" styleClass="mobile-logout-btn" text="Keluar 🚪" focusTraversable="false" />
    </HBox>

    <ScrollPane
        fitToWidth="true"
        style="-fx-background-color: transparent; -fx-background: transparent;"
        VBox.vgrow="ALWAYS"
    >
        <VBox spacing="20.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>

            <Label text="Selamat datang kembali!" styleClass="mobile-subtitle" />

            <!-- Stats Row -->
            <HBox spacing="10.0" fillHeight="true">
                <VBox
                    spacing="5.0"
                    styleClass="mobile-stats-card"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                >
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15" />
                    </padding>
                    <Label
                        text="Total Penjualan"
                        style="-fx-text-fill: white; -fx-font-size: 12px;"
                    />
                    <Label
                        text="Rp 2.4M"
                        style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
                    />
                </VBox>
                <VBox
                    spacing="5.0"
                    styleClass="mobile-stats-card-alt"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                >
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15" />
                    </padding>
                    <Label
                        text="Pesanan"
                        style="-fx-text-fill: white; -fx-font-size: 12px;"
                    />
                    <Label
                        text="42"
                        style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
                    />
                </VBox>
            </HBox>

            <Label text="Tindakan Cepat" styleClass="mobile-subtitle" />

            <!-- POS Actions Grid with Premium Colored Icons -->
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints
                        hgrow="ALWAYS"
                        minWidth="10.0"
                        percentWidth="50.0"
                    />
                    <ColumnConstraints
                        hgrow="ALWAYS"
                        minWidth="10.0"
                        percentWidth="50.0"
                    />
                </columnConstraints>

                <!-- New Sale -->
                <Button
                    onAction="#handleNewSale"
                    GridPane.columnIndex="0"
                    GridPane.rowIndex="0"
                    maxWidth="Infinity"
                    minHeight="120"
                    styleClass="dashboard-menu-btn"
                    focusTraversable="false"
                >
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <StackPane styleClass="menu-icon-container, icon-bg-blue">
                                    <children>
                                        <Label text="🛒" style="-fx-font-size: 22px; -fx-text-fill: white;" />
                                    </children>
                                </StackPane>
                                <Label text="Penjualan Baru" styleClass="menu-btn-label" />
                            </children>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Inventory -->
                <Button
                    onAction="#handleInventory"
                    GridPane.columnIndex="1"
                    GridPane.rowIndex="0"
                    maxWidth="Infinity"
                    minHeight="120"
                    styleClass="dashboard-menu-btn"
                    focusTraversable="false"
                >
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <StackPane styleClass="menu-icon-container, icon-bg-purple">
                                    <children>
                                        <Label text="📦" style="-fx-font-size: 22px; -fx-text-fill: white;" />
                                    </children>
                                </StackPane>
                                <Label text="Inventaris" styleClass="menu-btn-label" />
                            </children>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Reports -->
                <Button
                    onAction="#handleReports"
                    GridPane.columnIndex="0"
                    GridPane.rowIndex="1"
                    maxWidth="Infinity"
                    minHeight="120"
                    styleClass="dashboard-menu-btn"
                    focusTraversable="false"
                >
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <StackPane styleClass="menu-icon-container, icon-bg-green">
                                    <children>
                                        <Label text="📊" style="-fx-font-size: 22px; -fx-text-fill: white;" />
                                    </children>
                                </StackPane>
                                <Label text="Laporan" styleClass="menu-btn-label" />
                            </children>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Settings -->
                <Button
                    onAction="#handleSettings"
                    GridPane.columnIndex="1"
                    GridPane.rowIndex="1"
                    maxWidth="Infinity"
                    minHeight="120"
                    styleClass="dashboard-menu-btn"
                    focusTraversable="false"
                >
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <StackPane styleClass="menu-icon-container, icon-bg-orange">
                                    <children>
                                        <Label text="⚙️" style="-fx-font-size: 22px; -fx-text-fill: white;" />
                                    </children>
                                </StackPane>
                                <Label text="Pengaturan" styleClass="menu-btn-label" />
                            </children>
                        </VBox>
                    </graphic>
                </Button>
            </GridPane>

            <!-- Recent Transactions styled identical to Reports list -->
            <Label text="Transaksi Terakhir" styleClass="mobile-subtitle" />

            <VBox spacing="10.0">
                <!-- Transaction Item 1 -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="transaction-row-card">
                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18"/>
                    </padding>
                    <children>
                        <VBox HBox.hgrow="ALWAYS" spacing="4">
                            <children>
                                <Label text="Andi - Martabak Manis" styleClass="transaction-customer-title" />
                                <Label text="Kuantitas: 2 pcs • Tunai" styleClass="transaction-details" />
                            </children>
                        </VBox>
                        <Label text="Rp 50.000" styleClass="transaction-amount" />
                    </children>
                </HBox>

                <!-- Transaction Item 2 -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="transaction-row-card">
                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18"/>
                    </padding>
                    <children>
                        <VBox HBox.hgrow="ALWAYS" spacing="4">
                            <children>
                                <Label text="Budi - Martabak Asin" styleClass="transaction-customer-title" />
                                <Label text="Kuantitas: 1 pcs • QRIS" styleClass="transaction-details" />
                            </children>
                        </VBox>
                        <Label text="Rp 22.000" styleClass="transaction-amount" />
                    </children>
                </HBox>
                
                <!-- Transaction Item 3 -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="transaction-row-card">
                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18"/>
                    </padding>
                    <children>
                        <VBox HBox.hgrow="ALWAYS" spacing="4">
                            <children>
                                <Label text="Citra - Martabak Manis Spesial" styleClass="transaction-customer-title" />
                                <Label text="Kuantitas: 1 pcs • QRIS" styleClass="transaction-details" />
                            </children>
                        </VBox>
                        <Label text="Rp 35.000" styleClass="transaction-amount" />
                    </children>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- Bottom Nav -->
    <HBox alignment="CENTER" spacing="0.0" styleClass="mobile-bottom-nav">
        <Button
            text="Beranda"
            styleClass="mobile-nav-item, active"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="🏠" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Penjualan"
            onAction="#handleNewSale"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="🛍️" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Inventaris"
            onAction="#handleInventory"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="📦" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Lainnya"
            onAction="#handleSettings"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
            focusTraversable="false"
        >
            <graphic>
                <Label text="☰" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
    </HBox>
</VBox>

