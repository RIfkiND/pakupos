<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aulkhami.pakupos.views.components.SimpleCardController"
      spacing="8" style="-fx-background-color: #ffffff; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8;">
    <padding>
        <Insets top="14" right="14" bottom="14" left="14"/>
    </padding>
    <children>
        <Label fx:id="titleLabel" text="Judul" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label fx:id="bodyLabel" text="Isi" wrapText="true"/>
    </children>
</VBox>
