<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="0.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aulkhami.pakupos.controllers.SettingsController"
      styleClass="mobile-root" stylesheets="@css/main.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-header">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20"/>
        </padding>
        <Button text="←" onAction="#handleBack" styleClass="mobile-button-header" style="-fx-font-size: 18px;"/>
        <Label text="Settings" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0"/>
            </font>
        </Label>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="20.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Profile Card -->
            <VBox spacing="10.0" styleClass="mobile-recent-list" style="-fx-padding: 20; -fx-alignment: CENTER;">
                <Label text="👤" style="-fx-font-size: 48px;"/>
                <Label fx:id="nameLabel" text="User Name" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label fx:id="roleLabel" text="Role" style="-fx-text-fill: #0d6efd; -fx-font-weight: bold; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Account Info -->
            <Label text="Profile Settings" styleClass="mobile-subtitle" />
            <VBox spacing="0.0" styleClass="mobile-recent-list">
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-recent-item">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Email" style="-fx-font-size: 11px; -fx-text-fill: gray;"/>
                        <Label fx:id="emailLabel" text="email@example.com" style="-fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-recent-item">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Phone" style="-fx-font-size: 11px; -fx-text-fill: gray;"/>
                        <Label fx:id="phoneLabel" text="+62 812..." style="-fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
                <Button onAction="#handleChangePassword" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: center-left;">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                            <Label text="🔒" style="-fx-font-size: 16px;"/>
                            <Label text="Change Password" style="-fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="›" style="-fx-font-size: 20px; -fx-text-fill: #adb5bd;"/>
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <!-- Admin Section -->
            <VBox fx:id="adminSection" spacing="10.0">
                <Label text="Administration" styleClass="mobile-subtitle" />
                <VBox spacing="0.0" styleClass="mobile-recent-list">
                    <Button onAction="#handleUserManagement" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: center-left;">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="👥" style="-fx-font-size: 16px;"/>
                                <Label text="User Management" style="-fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="›" style="-fx-font-size: 20px; -fx-text-fill: #adb5bd;"/>
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>
            </VBox>

            <!-- Logout -->
            <Button text="LOGOUT" onAction="#handleLogout" maxWidth="Infinity" styleClass="mobile-button-secondary" style="-fx-text-fill: #dc3545; -fx-border-color: #dc3545;">
                <VBox.margin>
                    <Insets top="10" bottom="20"/>
                </VBox.margin>
            </Button>

            <Label text="App Version 1.0.0" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #adb5bd; -fx-font-size: 11px;"/>
        </VBox>
    </ScrollPane>

    <!-- Bottom Nav -->
    <HBox alignment="CENTER" spacing="0.0" styleClass="mobile-bottom-nav">
        <Button text="Home" onAction="#handleBack" styleClass="mobile-nav-item" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <graphic>
                <Label text="🏠" styleClass="mobile-nav-icon"/>
            </graphic>
        </Button>
        <Button text="Sales" onAction="#handleNewSale" styleClass="mobile-nav-item" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <graphic>
                <Label text="🛍️" styleClass="mobile-nav-icon"/>
            </graphic>
        </Button>
        <Button text="Inventory" onAction="#handleInventory" styleClass="mobile-nav-item" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <graphic>
                <Label text="📦" styleClass="mobile-nav-icon"/>
            </graphic>
        </Button>
        <Button text="More" styleClass="mobile-nav-item, active" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <graphic>
                <Label text="☰" styleClass="mobile-nav-icon"/>
            </graphic>
        </Button>
    </HBox>
</VBox>
