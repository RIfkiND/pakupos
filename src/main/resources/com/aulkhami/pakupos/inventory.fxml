<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<VBox
    spacing="0.0"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.aulkhami.pakupos.controllers.InventoryController"
    styleClass="mobile-root"
    stylesheets="@css/main.css"
>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="mobile-header">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20" />
        </padding>
        <Button
            text="←"
            onAction="#handleBack"
            styleClass="mobile-button-header"
            style="-fx-font-size: 18px;"
        />
        <Label text="Inventory Management" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
    </HBox>

    <ScrollPane
        fitToWidth="true"
        style="-fx-background-color: transparent; -fx-background: transparent;"
        VBox.vgrow="ALWAYS"
    >
        <VBox spacing="20.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>

            <Label text="Add New Product" styleClass="mobile-subtitle" />

            <VBox spacing="15.0">
                <VBox spacing="5.0">
                    <Label
                        text="Product Name *"
                        style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"
                    />
                    <TextField
                        fx:id="nameField"
                        promptText="e.g. Espresso"
                        styleClass="mobile-input"
                        maxWidth="Infinity"
                    />
                </VBox>

                <VBox spacing="5.0">
                    <Label
                        text="Category"
                        style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"
                    />
                    <TextField
                        fx:id="categoryField"
                        promptText="e.g. Coffee"
                        styleClass="mobile-input"
                        maxWidth="Infinity"
                    />
                </VBox>

                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label
                            text="Price (Rp) *"
                            style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"
                        />
                        <TextField
                            fx:id="priceField"
                            promptText="0"
                            styleClass="mobile-input"
                            maxWidth="Infinity"
                        />
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label
                            text="Stock *"
                            style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"
                        />
                        <TextField
                            fx:id="stockField"
                            promptText="0"
                            styleClass="mobile-input"
                            maxWidth="Infinity"
                        />
                    </VBox>
                </HBox>

                <Button
                    text="SAVE PRODUCT"
                    onAction="#handleSaveProduct"
                    maxWidth="Infinity"
                    styleClass="mobile-button-primary"
                    style="-fx-margin: 10 0 0 0;"
                >
                    <VBox.margin>
                        <Insets top="20" />
                    </VBox.margin>
                </Button>
            </VBox>

            <Separator />

            <Label text="Current Inventory" styleClass="mobile-subtitle" />
            <VBox
                fx:id="productListVBox"
                spacing="0.0"
                styleClass="mobile-recent-list"
            >
                <!-- Products will be loaded here dynamically -->
            </VBox>

            <Separator />

            <Label text="Quick Help" styleClass="mobile-subtitle" />

            <Label
                text="Fields marked with * are required. Make sure price and stock are numeric values."
                wrapText="true"
                style="-fx-text-fill: #6c757d; -fx-font-size: 13px;"
            />
        </VBox>
    </ScrollPane>

    <!-- Bottom Nav Placeholder (Keeping consistency) -->
    <HBox alignment="CENTER" spacing="0.0" styleClass="mobile-bottom-nav">
        <Button
            text="Home"
            onAction="#handleBack"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
        >
            <graphic>
                <Label text="🏠" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Sales"
            onAction="#handleNewSale"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
        >
            <graphic>
                <Label text="🛍️" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="Inventory"
            styleClass="mobile-nav-item, active"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
        >
            <graphic>
                <Label text="📦" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
        <Button
            text="More"
            onAction="#handleSettings"
            styleClass="mobile-nav-item"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity"
        >
            <graphic>
                <Label text="☰" styleClass="mobile-nav-icon" />
            </graphic>
        </Button>
    </HBox>
</VBox>
